{
  "schema_version": "tui-metadata.v3",
  "version": "agomtui-rich-components.v0",
  "registry_key": "rich-components",
  "default_screen": "overview.rich",
  "interaction_model": "published-metadata-to-pc-tools",
  "groups": [
    {"key": "workbench", "label": "Workbench"}
  ],
  "modules": [
    {
      "key": "overview",
      "label": "Overview",
      "group": "workbench",
      "summary": "Rich component examples for metadata-driven renderers."
    }
  ],
  "screens": [
    {
      "key": "overview.rich",
      "label": "Rich Components",
      "module_key": "overview",
      "group": "workbench",
      "summary": "Demonstrate chart, table-chart, and host slot metadata.",
      "view_type": "status",
      "dashboard_panels": [
        {
          "key": "nav-trend",
          "title": "NAV Trend",
          "kind": "chart",
          "action_key": "overview.nav_trend"
        },
        {
          "key": "allocation-table-chart",
          "title": "Allocation Table + Chart",
          "kind": "table_chart",
          "action_key": "overview.allocation"
        },
        {
          "key": "host-partial",
          "title": "Host Partial",
          "kind": "host_slot",
          "action_key": "overview.host_partial"
        },
        {
          "key": "image-preview",
          "title": "Image Preview",
          "kind": "image",
          "action_key": "overview.image_preview"
        }
      ]
    }
  ],
  "actions": [
    {
      "key": "overview.nav_trend",
      "label": "NAV Trend",
      "endpoint": "/api/tui-example/nav-trend/",
      "intent": "read_nav_trend",
      "screen_key": "overview.rich",
      "view_type": "chart",
      "risk": "read",
      "source": "openapi:example",
      "view_model": {
        "kind": "chart",
        "renderer": "line",
        "chart_type": "line",
        "data_path": "data.history",
        "x_path": "date",
        "y_path": "nav"
      }
    },
    {
      "key": "overview.allocation",
      "label": "Allocation Table + Chart",
      "endpoint": "/api/tui-example/allocation/",
      "intent": "read_allocation",
      "screen_key": "overview.rich",
      "view_type": "table_chart",
      "risk": "read",
      "source": "openapi:example",
      "view_model": {
        "kind": "table_chart",
        "renderer": "bar",
        "chart_type": "bar",
        "data_path": "data.rows",
        "x_path": "asset",
        "y_path": "weight",
        "table_rows_path": "data.rows"
      }
    },
    {
      "key": "overview.host_partial",
      "label": "Host Partial",
      "endpoint": "/api/tui-example/host-partial/",
      "intent": "read_host_partial",
      "screen_key": "overview.rich",
      "view_type": "host_slot",
      "risk": "read",
      "source": "openapi:example",
      "view_model": {
        "kind": "host_slot",
        "renderer": "host-slot",
        "slot_key": "overview-host-partial",
        "partial_path": "data.partial_html",
        "fallback_message": "Host partial rendering is disabled until the host enables HTML slots."
      }
    },
    {
      "key": "overview.image_preview",
      "label": "Image Preview",
      "endpoint": "/api/tui-example/image-preview/",
      "intent": "read_image_preview",
      "screen_key": "overview.rich",
      "view_type": "image",
      "risk": "read",
      "source": "openapi:example",
      "view_model": {
        "kind": "image",
        "url_path": "data.image_url",
        "alt_path": "data.alt",
        "caption_path": "data.caption"
      }
    }
  ]
}
